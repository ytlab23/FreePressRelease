# freepressrelease.io — static marketing site
# ---------------------------------------------------------------------------
# Published press releases are rendered by the portal app
# (my.freepressrelease.io) and surfaced on this apex under /press/<slug> via a
# path-preserving reverse proxy. The browser URL stays freepressrelease.io.
#
# Requires Apache mod_proxy + mod_proxy_http (and mod_rewrite). On cPanel these
# are usually enabled; if mod_proxy is unavailable on your plan, serve /press
# from a CDN/edge rewrite instead (Cloudflare rule or move this site to a host
# with rewrites). See PRESS-INTEGRATION.md.

RewriteEngine On

# Public release pages: freepressrelease.io/press/<slug> -> portal app.
RewriteRule ^press/?$        https://my.freepressrelease.io/press [P,L]
RewriteRule ^press/(.+)$     https://my.freepressrelease.io/press/$1 [P,L]

# Contact form POST -> portal API (same-origin, no CORS).
RewriteRule ^api/contact$    https://my.freepressrelease.io/api/contact [P,L]

# Release sitemap + RSS (DB-backed, generated by the app).
RewriteRule ^press-sitemap\.xml$  https://my.freepressrelease.io/sitemap.xml [P,L]
RewriteRule ^press-rss\.xml$       https://my.freepressrelease.io/rss [P,L]

# Preserve the original Host so the app can build correct absolute URLs.
<IfModule mod_proxy.c>
  ProxyPreserveHost On
</IfModule>
